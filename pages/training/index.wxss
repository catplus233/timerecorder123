.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-state, .completed-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 32rpx;
  color: #666666;
}

.completed-icon {
  font-size: 160rpx;
  margin-bottom: 40rpx;
}

.completed-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.completed-subtitle {
  font-size: 30rpx;
  color: #666666;
  margin-bottom: 60rpx;
}

.return-btn {
  background: linear-gradient(135deg, #4fc3f7 0%, #29b6f6 100%);
  color: #ffffff;
  font-size: 32rpx;
  padding: 28rpx 80rpx;
  border-radius: 50rpx;
  border: none;
}

.training-state {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(41, 182, 246, 0.2);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4fc3f7, #29b6f6);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 60rpx;
}

.state-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.state-text {
  font-size: 36rpx;
  color: #333333;
  margin-bottom: 20rpx;
}

.countdown {
  font-size: 200rpx;
  font-weight: bold;
  color: #29b6f6;
  line-height: 1;
  text-shadow: 0 4rpx 20rpx rgba(79, 195, 247, 0.3);
}

.countdown-unit {
  font-size: 36rpx;
  color: #666666;
  margin-top: 10rpx;
}

.action-hint {
  background: rgba(255,255,255,0.9);
  border-radius: 20rpx;
  padding: 24rpx 48rpx;
  margin-bottom: 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(79, 195, 247, 0.15);
}

.action-hint text {
  font-size: 30rpx;
  color: #333333;
}

.controls {
  display: flex;
  gap: 30rpx;
  width: 100%;
}

.control-btn {
  flex: 1;
  font-size: 32rpx;
  padding: 28rpx 0;
  border-radius: 50rpx;
  border: none;
}

.control-btn.pause {
  background: linear-gradient(135deg, #4fc3f7 0%, #29b6f6 100%);
  color: #ffffff;
}

.control-btn.stop {
  background: #fff0f0;
  color: #ff6b6b;
}
