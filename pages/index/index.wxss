.page {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f5f9fc;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  width: 100%;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.create-btn {
  background: linear-gradient(135deg, #4fc3f7 0%, #29b6f6 100%);
  color: #ffffff;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.status-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 200rpx;
}

.status-text {
  color: #666666;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  color: #333333;
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  color: #999999;
  font-size: 26rpx;
}

.list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(79, 195, 247, 0.1);
}

.item-top {
  margin-bottom: 12rpx;
}

.item-name {
  color: #333333;
  font-size: 30rpx;
  font-weight: bold;
  word-break: break-word;
}

.item-bottom {
  margin-bottom: 20rpx;
}

.item-meta {
  color: #666666;
  font-size: 24rpx;
}

.item-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.btn-group-right {
  display: flex;
  gap: 12rpx;
}

.btn-primary {
  width: 180rpx;
  text-align: center;
  font-size: 24rpx;
  padding: 14rpx 0;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #4fc3f7 0%, #29b6f6 100%);
  color: #ffffff;
}

.btn-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 28rpx;
}

.btn-edit {
  margin-right: 16rpx;
  background: #f0f7fc;
  color: #29b6f6;
}

.btn-delete {
  background: #fff0f0;
  color: #ff6b6b;
}
